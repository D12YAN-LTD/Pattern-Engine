//@version=6
indicator("Pattern Engine v0.30 Debug", overlay=true, max_labels_count=500)

//=============================================================================
// PATTERN ENGINE v0.30 DEBUG
// Checkpoint 1 - Power Move
//
// Author:
// Daniel Ryan + ChatGPT
//
// Build v0.30
// Changes:
// - Corrected version headers.
// - Debug build for CP1 validation.
//
// Purpose:
// Detect institutional Power Moves and build a reusable
// Pattern Engine for future checkpoints.
//
// Future:
// CP2 Healthy Pullback
// CP3 Trend Maintenance
// CP4A Classical Coil
// CP4B EMA Compression
// CP5 Expansion
//=============================================================================


//=============================================================================
// INPUTS
//=============================================================================

groupCP1 = "Checkpoint 1 - Power Move"

minGainPercent     = input.float(30.0, "Minimum Gain (%)", group=groupCP1)
maxBars            = input.int(15, "Maximum Bars", minval=3, group=groupCP1)
pivotStrength      = input.int(3, "Pivot Strength", minval=1, maxval=10, group=groupCP1)
volumeLength       = input.int(20, "Volume SMA Length", group=groupCP1)
accumulationFactor = input.float(2.0, "Accumulation Multiplier", step=0.1, group=groupCP1)

showTable = input.bool(true, "Show Status Table")


//=============================================================================
// ENUMS
//=============================================================================

// State constants
int STATE_SEARCHING = 0
int STATE_TRACKING = 1
int STATE_LOCKED = 2


//=============================================================================
// CHECKPOINT 1 VARIABLES
//=============================================================================

var int cp1State = STATE_SEARCHING

var float cp1Low = na
var float cp1High = na
var float cp1Gain = na

var int cp1LowBar = na
var int cp1HighBar = na
var int cp1Bars = na

var bool cp1VolumePass = false
var bool cp1Complete = false


//=============================================================================
// HELPER VARIABLES
//=============================================================================

volSMA = ta.sma(volume, volumeLength)

pivotLow = ta.pivotlow(low, pivotStrength, pivotStrength)


//=============================================================================
// STATUS TABLE
//=============================================================================

var table status = table.new(position.top_right, 2, 8, border_width=1)

//if barstate.islast and showTable

if showTable

    table.cell(status,0,0,"Pattern Engine",bgcolor=color.blue,text_color=color.white)

    table.cell(status,1,0,"v0.20", text_color=color.white)

    table.cell(status,0,1,"Checkpoint", text_color=color.white)

    table.cell(status,1,1,"CP1", text_color=color.white)

    table.cell(status,0,2,"State", text_color=color.white)

    table.cell(status,1,2,
         cp1State == STATE_SEARCHING ? "Searching" :
         cp1State == STATE_TRACKING ? "Tracking" :
         "Locked", text_color=color.white)

    table.cell(status,0,3,"Gain", text_color=color.white)

    table.cell(status,1,3,
         na(cp1Gain) ? "-" : str.tostring(cp1Gain,"#.0")+"%", text_color=color.white)

    table.cell(status,0,4,"Bars", text_color=color.white)

    table.cell(status,1,4,
         na(cp1Bars) ? "-" : str.tostring(cp1Bars), text_color=color.white)

    table.cell(status,0,5,"Volume", text_color=color.white)

    table.cell(status,1,5,
         cp1VolumePass ? "PASS" : "-", text_color=color.white)

    table.cell(status,0,6,"Status", text_color=color.white)

    table.cell(status,1,6,
         cp1Complete ? "Waiting CP2" : "Searching", text_color=color.white)

    table.cell(status,0,7,"Build", text_color=color.white)

    table.cell(status,1,7,"Tracking", text_color=color.white)

//=============================================================================
// DEBUG PLOTS
//=============================================================================

//plotchar(cp1State == STATE_SEARCHING,
 //    title="Searching",
 //   char="S",
 //    location=location.bottom,
 //    color=color.gray)

//plotchar(cp1State == STATE_TRACKING,
 //    title="Tracking",
  //   char="T",
   //  location=location.bottom,
    // color=color.orange)

//plotchar(cp1State == STATE_LOCKED,
 //    title="Locked",
  //   char="L",
   //  location=location.bottom,
    // color=color.green)


//=============================================================================
// CHECKPOINT 1 ENGINE
//=============================================================================

//---------------------------------------------------------
// SEARCHING
//---------------------------------------------------------

if cp1State == STATE_SEARCHING

    if not na(pivotLow)

        cp1Low := pivotLow
        cp1LowBar := bar_index - pivotStrength

        cp1High := high
        cp1HighBar := bar_index

        cp1Gain := 0.0
        cp1Bars := 0

        cp1VolumePass := false
        cp1Complete := false

        cp1State := STATE_TRACKING


//---------------------------------------------------------
// TRACKING
//---------------------------------------------------------

if cp1State == STATE_TRACKING

    //-----------------------------------------------------
    // Update highest high
    //-----------------------------------------------------

    if high > cp1High
        cp1High := high
        cp1HighBar := bar_index

    //-----------------------------------------------------
    // Calculate move
    //-----------------------------------------------------

    cp1Gain := ((cp1High - cp1Low) / cp1Low) * 100.0

    cp1Bars := cp1HighBar - cp1LowBar + 1

    //-----------------------------------------------------
    // Detect accumulation day
    //-----------------------------------------------------

    if volume >= accumulationFactor * volSMA
        cp1VolumePass := true

    //-----------------------------------------------------
    // Lock Checkpoint 1
    //-----------------------------------------------------

    if not cp1Complete and cp1Gain >= minGainPercent and cp1Bars <= maxBars and cp1VolumePass
        cp1State := STATE_LOCKED
        cp1Complete := true

    //-----------------------------------------------------
    // Give up if move takes too long
    //-----------------------------------------------------

    if cp1Bars > maxBars
        cp1State := STATE_SEARCHING

        cp1Low := na
        cp1High := na
        cp1Gain := na

        cp1LowBar := na
        cp1HighBar := na
        cp1Bars := na

        cp1VolumePass := false