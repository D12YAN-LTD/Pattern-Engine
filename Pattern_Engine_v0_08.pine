//@version=6
indicator("Pattern Engine v0.01", overlay=true, max_labels_count=500, max_lines_count=500)

//=============================================================================
// INPUTS
//=============================================================================

groupCP1 = "CP1 - Power Move"

lookbackBars = input.int(100, "Lookback Bars", minval=20, group=groupCP1)
pivotStrength = input.int(3, "Pivot Strength", minval=1, maxval=20, group=groupCP1)
minGainPct = input.float(30.0, "Minimum Gain %", step=0.1, group=groupCP1)
maxBars = input.int(15, "Maximum Bars", minval=3, maxval=100, group=groupCP1)
volumeMultiplier = input.float(2.0, "Volume Multiplier", step=0.1, group=groupCP1)

showTable = input.bool(true, "Show Dashboard")

//=============================================================================
// CALCULATIONS
//=============================================================================

volMA = ta.sma(volume, 20)

pivotLow = ta.pivotlow(low, pivotStrength, pivotStrength)

bool isAccumulation = volume > volMA * volumeMultiplier and close > open

//=============================================================================
// CP1 VARIABLES
//=============================================================================

var bool cp1Found = false
var int cp1PivotBar = na
var float cp1PivotPrice = na
var int cp1BarsAgo = na
var float cp1HighestHigh = na
var int cp1HighestBar = na
var float cp1GainPct = na
var int cp1MoveBars = na
var bool cp1Pass = false
var bool gainPass = false
var bool barsPass = false
var bool cp1Locked = false
var int cp1AccumDays = 0

//=============================================================================
// FIND LATEST CONFIRMED PIVOT
//=============================================================================

if not na(pivotLow)
    cp1Found := true
    cp1PivotPrice := pivotLow
    cp1PivotBar := bar_index - pivotStrength
    cp1HighestHigh := high
    cp1HighestBar := bar_index

    cp1Locked := false
    cp1AccumDays := 0  

if cp1Found
    cp1BarsAgo := bar_index - cp1PivotBar

    //if high > cp1HighestHigh
    //    cp1HighestHigh := high
    //    cp1HighestBar := bar_index

    if cp1Found and not cp1Locked
        if high > cp1HighestHigh
            //cp1HighestHigh := high
            //cp1HighestBar := bar_index
            cp1HighestHigh := high[pivotStrength]
            cp1HighestBar := bar_index - pivotStrength            

    //if cp1Found and not cp1Locked
    //    if isAccumulation
    //        cp1AccumDays += 1

    if cp1Found and not cp1Locked
        if isAccumulation
            cp1AccumDays += 1

    //cp1GainPct := ((cp1HighestHigh - cp1PivotPrice) / cp1PivotPrice) * 100
    //cp1MoveBars := cp1HighestBar - cp1PivotBar    

    cp1GainPct := ((cp1HighestHigh - cp1PivotPrice) / cp1PivotPrice) * 100
    cp1MoveBars := cp1HighestBar - cp1PivotBar

    //cp1Pass := cp1GainPct >= minGainPct and cp1MoveBars <= maxBars

    //gainPass := cp1GainPct >= minGainPct
    //barsPass := cp1MoveBars <= maxBars

    //cp1Pass := gainPass and barsPass

    gainPass := cp1GainPct >= minGainPct
    barsPass := cp1MoveBars <= maxBars

    cp1Pass := gainPass and barsPass

    if cp1Pass
        cp1Locked := true

    //cp1AccumDays := 0    

//=============================================================================
// PLACEHOLDER
//=============================================================================

// Detection engine starts in v0.02

//=============================================================================
// VISUALS
//=============================================================================

//plotshape(not na(pivotLow),
//     title="Pivot Low",
//     style=shape.circle,
//     color=color.lime,
//     location=location.belowbar,
//     offset=-pivotStrength,
//     size=size.tiny)

//plotshape(
//     cp1Pass,
//     title="CP1 Pass",
//     style=shape.flag,
//     location=location.abovebar,
//     color=color.green,
//     size=size.small)

recentPivot = ta.barssince(not na(pivotLow)) < 50

plotshape(
     not na(pivotLow) and recentPivot,
     title="Pivot Low",
     style=shape.circle,
     color=color.lime,
     location=location.belowbar,
     offset=-pivotStrength,
     size=size.tiny)

recentPass = ta.barssince(cp1Pass) < 50

plotshape(
     cp1Pass and recentPass,
     title="CP1 Pass",
     style=shape.flag,
     location=location.abovebar,
     color=color.green,
     size=size.small)    

plotshape(isAccumulation,
     title="Accumulation",
     style=shape.triangleup,
     color=color.blue,
     location=location.belowbar,
     size=size.tiny)

//label.new(
//     cp1HighestBar,
//     cp1HighestHigh,
//     "CP1 PASS\nGain: " + str.tostring(cp1GainPct, "#.0") + "%\nBars: " + str.tostring(cp1MoveBars),
//     style=label.style_label_down,
//     color=color.green,
//     textcolor=color.white)    

//=============================================================================
// DASHBOARD
//=============================================================================

//var table t = table.new(position.top_right, 2, 8, border_width=1)

var table t = table.new(position.top_right, 2, 12, border_width=1)

if barstate.islast and showTable

    table.cell(t, 0, 1, "Pivot Found", text_color=color.white)
    table.cell(t, 1, 1, cp1Found ? "YES" : "NO", text_color=color.white)

    table.cell(t, 0, 2, "Pivot Price", text_color=color.white)
    table.cell(t, 1, 2, cp1Found ? str.tostring(cp1PivotPrice, "#.00") : "-", text_color=color.white)

    table.cell(t, 0, 3, "Pivot Bar", text_color=color.white)
    table.cell(t, 1, 3, cp1Found ? str.tostring(cp1PivotBar) : "-", text_color=color.white)

    table.cell(t, 0, 4, "Bars Ago", text_color=color.white)
    table.cell(t, 1, 4, cp1Found ? str.tostring(cp1BarsAgo) : "-", text_color=color.white)

    //table.cell(t, 0, 5, "Volume", text_color=color.white)
    //table.cell(t, 1, 5, isAccumulation ? "YES" : "NO", text_color=color.white)

    //table.cell(t, 0, 6, "Status", text_color=color.white)
    //table.cell(t, 1, 6, "v0.02", text_color=color.white)

    //table.cell(t, 0, 5, "Highest High", text_color=color.white)
    //table.cell(t, 1, 5, cp1Found ? str.tostring(cp1HighestHigh, "#.00") : "-", text_color=color.white)

    //table.cell(t, 0, 6, "High Bar", text_color=color.white)
    //table.cell(t, 1, 6, cp1Found ? str.tostring(cp1HighestBar) : "-", text_color=color.white)

    //table.cell(t, 0, 7, "Status", text_color=color.white)
    //table.cell(t, 1, 7, "v0.03", text_color=color.white)

    table.cell(t, 0, 5, "Highest High", text_color=color.white)
    table.cell(t, 1, 5, str.tostring(cp1HighestHigh, "#.00"), text_color=color.white)

    //table.cell(t, 0, 6, "Gain %", text_color=color.white)
    //table.cell(t, 1, 6, str.tostring(cp1GainPct, "#.0"), text_color=color.white)

    //table.cell(t, 0, 7, "Move Bars", text_color=color.white)
    //table.cell(t, 1, 7, str.tostring(cp1MoveBars), text_color=color.white)

    // Gain %

    table.cell(t, 0, 6, "Gain %", text_color=color.white)

    table.cell(
        t,
        1,
        6,
        str.tostring(cp1GainPct, "#.0") + "%",
        text_color=color.white,
        bgcolor=gainPass ? color.new(color.green, 0) : color.new(color.red, 0))

    // Move Bars

    table.cell(t, 0, 7, "Move Bars", text_color=color.white)

    table.cell(
        t,
        1,
        7,
        str.tostring(cp1MoveBars),
        text_color=color.white,
        bgcolor=barsPass ? color.new(color.green, 0) : color.new(color.red, 0))

    // CP1 PASS

    table.cell(t, 0, 8, "CP1 PASS", text_color=color.white)

    table.cell(
        t,
        1,
        8,
        cp1Pass ? "YES" : "NO",
        text_color=color.white,
        bgcolor=cp1Pass ? color.new(color.green, 0) : color.new(color.red, 0)) 

    table.cell(t, 0, 9, "Locked", text_color=color.white)

    table.cell(
        t,
        1,
        9,
        cp1Locked ? "YES" : "NO",
        text_color=color.white,
        bgcolor=cp1Locked ? color.new(color.green, 0) : color.new(color.red, 0))    

    table.cell(t, 0, 10, "Accum Days", text_color=color.white)

    table.cell(
        t,
        1,
        10,
        str.tostring(cp1AccumDays),
        text_color=color.white)


table.cell(t, 0, 11, "Accum Bar", text_color=color.white)

table.cell(
    t,
    1,
    11,
    isAccumulation ? "YES" : "NO",
    text_color=color.white,
    bgcolor=isAccumulation ? color.new(color.blue, 0) : color.new(color.red, 0))


